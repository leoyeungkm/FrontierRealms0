# 遊戲伺服器（Colyseus）環境變數
# 留空 = 對應功能停用，遊戲照常

# 鏈上 ownership 驗證（外觀 NFT）
FR0_PACKAGE_ID=0x1712a9d8fcb6a6325a2336156d9257fa4afc5b3b215985edf85750d53ba7d1fd
FR0_SUI_NETWORK=testnet

# 預測市場自動結算（server 當 oracle）。建議用「專用」錢包，勿用主錢包私鑰！
FR0_MARKET_ID=0x585a99d8d30f146a0612e4d63be52fc0a74628b16b38ee71ed912e037cefde8f
FR0_MARKET_CAP=0x920b1a44b2fda1a7905b51ca4761e4fff66b9f536589a2fd0c98feb90834ebce
FR0_ADMIN_SECRET=          # suiprivkey...（持有 MARKET_CAP 的錢包私鑰；只放這、勿進 git）
FR0_MARKET_FEE_BPS=200
FR0_MARKET_SEED_MIST=50000000   # 開新市場的種子流動性（0.05 SUI）
