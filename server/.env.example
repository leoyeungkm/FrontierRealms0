# 遊戲伺服器（Colyseus）環境變數
# 留空 = 對應功能停用，遊戲照常

# 鏈上 ownership 驗證（外觀 NFT）
FR0_PACKAGE_ID=0x1712a9d8fcb6a6325a2336156d9257fa4afc5b3b215985edf85750d53ba7d1fd
FR0_SUI_NETWORK=testnet

# 預測市場自動結算（server 當 oracle）。建議用「專用」錢包，勿用主錢包私鑰！
FR0_MARKET_ID=0x585a99d8d30f146a0612e4d63be52fc0a74628b16b38ee71ed912e037cefde8f
FR0_MARKET_CAP=0x920b1a44b2fda1a7905b51ca4761e4fff66b9f536589a2fd0c98feb90834ebce
FR0_ADMIN_SECRET=          # suiprivkey...（持有 MARKET_CAP 的錢包私鑰；只放這、勿進 git）
FR0_MARKET_FEE_BPS=200
FR0_MARKET_SEED_MIST=50000000   # 開新市場的種子流動性（0.05 SUI）

# 角色等級結算（server 當 oracle）。與市場共用 FR0_ADMIN_SECRET（同一把 server 金鑰）。
# （舊）shared 角色，已被下方 owned Hero 取代
FR0_CHARACTER_PACKAGE=0x9b033e1c9eb1c9319ab6a2a35cb5baa38b48f84e2c89716c6bbc74c5beac6b39
FR0_CHARACTER_CAP=0x23abec706749029058ebe5975d1203179115d46f2913ef02ac3125ceffdea0fd

# Hero NFT（owned、可交易）等級結算：server 簽章 → 合約 ed25519 驗章。共用 FR0_ADMIN_SECRET。
FR0_HERO_PACKAGE=0xe51bd7edc04b6c101e79ac2438e67a778e2ba821e5fa66353d730a3a4578ab1c
FR0_HERO_CONFIG=0x0eef570e98739a109377dc593c277ddb99e206c63a50d2932723616892786ef9
FR0_HERO_ADMINCAP=0x6bca07b39aee1f9cb5902c4756c838873824cd80de21bbddd2d1883075e0948d
