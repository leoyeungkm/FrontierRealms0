# ─── FR0 鏈上設定（複製成 .env 並填值）─────────────────────────
# 全部留空 = 鏈上功能停用，遊戲照常單機/連線跑（優雅降級）

# Sui 合約（sui/deploy.ps1 部署後自動寫入）
VITE_FR0_PACKAGE_ID=
VITE_FR0_SUI_NETWORK=testnet

# Walrus 去中心化儲存端點（預設公開 testnet，可換自架/社群節點）
VITE_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
VITE_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
VITE_WALRUS_EPOCHS=5

# zkLogin（Google 社交登入）。留空 = 隱藏 Google 登入，只用錢包
# Google Cloud Console 建 OAuth 2.0 Client（Web），授權 redirect = 你的遊戲網址
VITE_GOOGLE_CLIENT_ID=
VITE_ZKLOGIN_PROVER=https://prover-dev.mystenlabs.com/v1
